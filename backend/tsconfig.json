{
  "compilerOptions": {
    "target": "ES2020",

    "module": "commonjs",

    "moduleResolution": "node",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "types": ["node"],
    "noEmit": true,

    "declaration": false,

    "sourceMap": false,
    "ignoreDeprecations": "6.0"
  },

  "include": ["migrated/**/*.ts"]
}
